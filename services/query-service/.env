# Query Database Configuration (CQRS Read Model)
QUERY_DB_HOST=query-db
QUERY_DB_PORT=5432
QUERY_DB_NAME=query_db
QUERY_DB_USER=query_user
QUERY_DB_PASSWORD=query_password

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_2024

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=query-service-consumer
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_EVENT_TOPIC_PREFIX=processing.
BATCH_SIZE=100

# Cache Configuration
CACHE_TTL=300

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
MAX_QUERY_RESULTS=10000
QUERY_TIMEOUT=30
