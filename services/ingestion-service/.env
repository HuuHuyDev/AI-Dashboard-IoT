MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_TOPIC=iot/sensors/#
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_IOT_LOGS=iot_logs

# Redis Configuration
REDIS_HOST=ingestion-redis
REDIS_PORT=6379
REDIS_PASSWORD=ingestion_redis_pass
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_PER_DEVICE=10
RATE_LIMIT_GLOBAL=1000

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=5
