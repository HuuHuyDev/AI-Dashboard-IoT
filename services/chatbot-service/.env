# Redis Configuration
REDIS_HOST=chatbot-redis
REDIS_PORT=6379
REDIS_PASSWORD=chatbot_redis_pass
REDIS_DB=0

# Session Configuration
SESSION_TTL=3600
SQL_CACHE_TTL=3600

# Google Gemini Configuration
GEMINI_API_KEY=AIzaSyAhaKvF0NG1P03TD2DI5FgOIsERiGlGNyg
GEMINI_MODEL=models/gemini-2.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=2000

# Gemini Rate Limiting (Optimized for faster responses)
GEMINI_MAX_RPM=15
GEMINI_RPM_WINDOW_SEC=60
GEMINI_429_MAX_RETRIES=3
GEMINI_429_MAX_TOTAL_WAIT_SEC=120

# Query Service Configuration
QUERY_SERVICE_URL=http://query-service:8002

# PostgreSQL Configuration (MCP Tools - connects to processing-db)
POSTGRES_HOST=processing-db
POSTGRES_PORT=5432
POSTGRES_USER=processing_user
POSTGRES_PASSWORD=processing_pass
POSTGRES_DB=processing_db

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
